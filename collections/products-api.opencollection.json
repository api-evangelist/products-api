          "info": {
            "name": "Products Retrieve Product",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.example.com/products/:productId",
            "params": [
              {
                "name": "productId",
                "value": "1725ff48-ab45-4bb5-9d02-88745177dedb",
