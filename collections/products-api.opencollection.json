            "name": "Retrieves Products",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.example.com/products",
            "auth": {
              "type": "apikey",
              "key": "api-key",
              "value": "{{api-key}}",
              "placement": "header"
            }
          },
          "docs": "Returns a list of all products for the authenticated user."
        },
        {
          "info": {
            "name": "Products Create Product",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.example.com/products",
